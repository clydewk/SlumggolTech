APP_ENV=development
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/slumggol
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_INGEST_MODE=polling
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_POLL_TIMEOUT_SECONDS=20
TELEGRAM_POLL_INTERVAL_SECONDS=1
TELEGRAM_POLL_LIMIT=50
ADMIN_API_TOKEN=replace-with-admin-token
PUBLIC_WEBHOOK_URL=
ENABLE_CLICKHOUSE=false
CLICKHOUSE_URL=https://your-clickhouse-host:8443
CLICKHOUSE_DATABASE=bot_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_ASYNC_INSERT=1
CLICKHOUSE_WAIT_FOR_ASYNC_INSERT=1
OUTBREAK_REFRESH_INTERVAL_MINUTES=5
METABASE_PORT=3000
METABASE_SITE_URL=http://localhost:3000
ANALYSIS_MODE=gated
DEMO_MODE_MAX_SPEND_USD=25
DEMO_MODE_TTL_MINUTES=120
HOT_CLAIM_MIN_GROUPS=2
HOT_CLAIM_LOOKBACK_MINUTES=60
